{
  "name": "algorand-dapp-landing",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "wallets:generate": "tsx scripts/generate_demo_wallets.ts",
    "start:server": "tsx server/event-brief-server.ts",
    "alert:service": "tsx scripts/bot/alertService.ts",
    "services": "npm run bot",
    "dev": "vite",
    "dev:all": "npx concurrently -n web,api -c blue,green \"npm run dev\" \"npm run start:server\"",
    "dev:stack": "npx concurrently -k -n web,api,bot -c blue,green,magenta \"npm run dev -- --open\" \"npm run start:server\" \"npm run bot\"",
    "stack:check": "tsx scripts/stack-health-check.ts",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "agent:service:DISABLED": "tsx scripts/agent_service.ts",
    "bot": "tsx scripts/bot/ensure-single-bot.ts && tsx scripts/bot/bot.ts",
    "prebot": "tsx scripts/bot/ensure-single-bot.ts",
    "telegram:test": "tsx scripts/bot/test-telegram.ts",
    "fund:humanitarian": "tsx scripts/fund_humanitarian.ts",
    "bootstrap:humanitarian": "tsx scripts/bootstrap_humanitarian.ts",
    "optin:usdc": "tsx scripts/optin_usdc.ts",
    "verify:lora": "tsx scripts/export_lora_verification.ts",
    "verify:deployment": "tsx scripts/verify_deployment.ts",
    "download:landing-images": "tsx scripts/download-landing-images.ts",
    "deploy:disaster-vault": "tsx scripts/deploy_disaster_vault.ts",
    "build:disaster-contract": "cd savings_vault/projects/disaster_vault && poetry run python -m smart_contracts build disaster_vault"
  },
  "dependencies": {
    "@algorandfoundation/algokit-utils": "^6.0.0",
    "@blockshake/defly-connect": "1.1.6",
    "@google/generative-ai": "^0.24.1",
    "@hookform/resolvers": "^5.2.2",
    "@perawallet/connect": "1.3.5",
    "@tanstack/react-query": "^5.100.10",
    "@txnlab/use-wallet-react": "^3.3.0",
    "@walletconnect/modal": "^2.7.0",
    "@walletconnect/sign-client": "^2.23.9",
    "@walletconnect/types": "^2.23.9",
    "algosdk": "^2.9.0",
    "body-parser": "^1.20.3",
    "canvas-confetti": "^1.9.4",
    "date-fns": "^4.1.0",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "framer-motion": "^12.38.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.16.0",
    "node-telegram-bot-api": "^0.66.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.76.0",
    "react-is": "^18.2.0",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^7.13.2",
    "recharts": "^3.8.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/body-parser": "^1.19.6",
    "@types/canvas-confetti": "^1.9.0",
    "@types/express": "^5.0.3",
    "@types/leaflet": "^1.9.21",
    "@types/node-telegram-bot-api": "^0.64.10",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/recharts": "^1.8.29",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.20.6",
    "typescript": "^5.3.3",
    "vite": "^5.0.8"
  }
}
