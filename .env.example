# Copy to `.env` for local dev / Vercel. Do not set VITE_APP_ADDRESS — the app derives it from VITE_APP_ID.

VITE_APP_ID=
VITE_ALGOD_SERVER=https://testnet-api.algonode.cloud
VITE_ALGOD_PORT=443
VITE_ALGOD_TOKEN=
VITE_INDEXER_SERVER=https://testnet-idx.algonode.cloud
VITE_INDEXER_PORT=443
VITE_NETWORK=testnet

# Optional: Gemini for AI summaries / chat
VITE_GEMINI_API_KEY=

# Guardian Portal deep-links (frontend safe)
# WhatsApp: digits only, e.g. 14155238886 (no "whatsapp:" prefix)
VITE_TWILIO_WHATSAPP_NUMBER=
# Telegram bot username without "@", e.g. AlgoVaultGuardianBot
VITE_TELEGRAM_BOT_USERNAME=

# Phase 3 (standalone Telegram agent bot)
# These are NOT used by the frontend; they are used by `npm run agent:*`.
TELEGRAM_BOT_TOKEN=
GEMINI_API_KEY=
AGENT_MNEMONIC=
APP_ID=
ALGOD_SERVER=https://testnet-api.algonode.cloud
ALGOD_PORT=443
ALGOD_TOKEN=

# Phase 3 (standalone WhatsApp agent bot via Twilio webhook)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
PORT=3000
