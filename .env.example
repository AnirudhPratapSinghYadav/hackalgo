# Copy to `.env` — never commit `.env`

# ── Algorand testnet ─────────────────────────────────────────────
VITE_NETWORK=testnet
VITE_ALGOD_SERVER=https://testnet-api.algonode.cloud
VITE_INDEXER_SERVER=https://testnet-idx.algonode.cloud
VITE_DISASTER_APP_ID=762592323
VITE_APPEALS_APP_ID=762592091
VITE_STABLECOIN_ASSET_ID=31566704
VITE_USE_REAL_CONTRACT=true

# Admin & approvers (three DISTINCT addresses for 2-of-2 demo)
VITE_ADMIN_ADDRESS=YOUR_ADMIN_ADDRESS_58_CHARS
VITE_DISASTER_APPROVER_0=DISTINCT_APPROVER_0_ADDRESS
VITE_DISASTER_APPROVER_1=DISTINCT_APPROVER_1_ADDRESS
VITE_DISASTER_APPROVER_2=DISTINCT_APPROVER_2_ADDRESS

# Demo mode
VITE_DEMO_STRICT=true
# false = show community appeals, anticipatory UI, full sidebar
VITE_DEMO_CORE_FOCUS=false
VITE_SHOW_SANDBOX=false

VITE_CAMPAIGN_TARGET_MICRO_USDC=10000000
VITE_CAMPAIGN_EXPIRY_ROUNDS=2000000

VITE_ALGOD_PORT=443
VITE_ALGOD_TOKEN=
VITE_INDEXER_PORT=443

# Savings lab (hidden when VITE_SHOW_SANDBOX=false)
VITE_APP_ID=758811663

# Event brief API — server only (no VITE_ prefix)
GEMINI_API_KEY=
GNEWS_API_KEY=
BRIEF_PORT=3001

# Alerts (UI deep links)
VITE_TELEGRAM_BOT_USERNAME=AlgoVault_Guardian_bot

# Telegram Guardian (npm run bot) — one process only
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
BOT_PORT=3002
PUBLIC_APP_URL=http://localhost:5173
BOT_MNEMONIC=

# Deploy / bootstrap (local only)
DEPLOYER_MNEMONIC=
AGENT_MNEMONIC=
ALGOD_SERVER=https://testnet-api.algonode.cloud
ALGOD_PORT=443
ALGOD_TOKEN=
